<!DOCTYPE html>
<html lang="pt-BR">

<%- include('../partials/header') %>

<body>

    <% if (session && session.user) { %>

        <% if (session.user.tipo === 'cliente') { %>
            <%- include('../partials/navbar_cliente') %>
        <% } %>

        <% if (session.user.tipo === 'barbeiro') { %>
            <%- include('../partials/navbar_barbeiro') %>
        <% } %>

    <% } else { %>

        <%- include('../partials/navbar_public') %>

    <% } %>

    <main aria-label="Conteúdo da política de privacidade">

        <!-- Título -->
        <section aria-label="Título da página">
            <h2>Política de Privacidade</h2>
            <p>Saiba como os dados são utilizados no BarberFlow.</p>
        </section>

        <!-- Dados -->
        <section aria-label="Coleta de dados">
            <h3>Coleta de dados</h3>
            <p>O BarberFlow armazena informações como nome, email e dados de agendamento.</p>
        </section>

        <!-- Segurança -->
        <section aria-label="Segurança das informações">
            <h3>Segurança</h3>
            <p>As informações cadastradas são protegidas e utilizadas apenas para funcionamento da plataforma.</p>
        </section>

        <!-- Sessão -->
        <section aria-label="Sessão do usuário">
            <h3>Sessão do usuário</h3>
            <p>O sistema utiliza sessões para manter o usuário autenticado durante o uso da plataforma.</p>
        </section>

    </main>

    <%- include('../partials/footer') %>

</body>
</html>
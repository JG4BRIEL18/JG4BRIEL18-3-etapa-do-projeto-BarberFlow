<!DOCTYPE html>
<html lang="pt-BR">

<%- include('partials/header') %>

<body>

    <%- include('partials/navbar_public') %>

    <main>

        <section class="form-container">
            <h2>Cadastro de Cliente</h2>

            <!-- Mensagem de erro -->

            <% if (erro) { %>
                <p class="mensagem-erro"><%= erro %></p>
            <% } %>

            <form method="POST" action="/cadastro/cliente" aria-label="Formulário de cadastro de cliente">

                <label for="nome">Nome completo</label>
                <input 
                    type="text" 
                    id="nome" 
                    name="nome" 
                    placeholder="Digite seu nome" 
                    required 
                    autocomplete="name"
                    aria-label="Campo de nome completo">

                <label for="emailCadastro">Email</label>
                <input 
                    type="email" 
                    id="emailCadastro" 
                    name="email" 
                    placeholder="Digite seu email" 
                    required 
                    autocomplete="email"
                    aria-label="Campo de email">

                <label for="senhaCadastro">Senha</label>
                <input 
                    type="password" 
                    id="senhaCadastro" 
                    name="senha" 
                    placeholder="Crie uma senha" 
                    required 
                    minlength="8" 
                    autocomplete="new-password"
                    aria-label="Campo de senha">
                <small>Mínimo de 8 caracteres</small>

                <label for="confirmarSenha">Confirmar senha</label>
                <input 
                    type="password" 
                    id="confirmarSenha" 
                    name="confirmarSenha" 
                    placeholder="Digite novamente a senha" 
                    required 
                    minlength="8" 
                    autocomplete="new-password"
                    aria-label="Campo de confirmação de senha">
                <small>Digite a mesma senha novamente</small>

                <button type="submit" aria-label="Cadastrar como cliente">Cadastrar</button>

            </form>
        </section>

    </main>

    <%- include('partials/footer') %>

</body>
</html>
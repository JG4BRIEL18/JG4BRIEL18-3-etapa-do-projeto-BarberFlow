<!DOCTYPE html>
<html lang="pt-BR">

<%- include('../partials/header') %>

<body>

    <%- include('../partials/navbar_barbeiro') %>

    <main aria-label="Conteúdo principal de serviços">

        <!-- Voltar -->

        <button
            class="botao"
            type="button"
            onclick="history.back()"
            aria-label="Voltar para página anterior"
        >
            Voltar
        </button>

        <!-- Mensagem de erro -->

        <% if (erro) { %>
            <p class="mensagem-erro"><%= erro %></p>
        <% } %>

        <!-- Mensagem de sucesso -->

        <% if (sucesso) { %>
            <p class="mensagem-sucesso"><%= sucesso %></p>
        <% } %>

        <!-- Serviços cadastrados -->

        <section aria-labelledby="titulo-servicos">
            <h2 id="titulo-servicos">Serviços</h2>

            <% if (servicos.length === 0) { %>

                <p>Nenhum serviço cadastrado ainda.</p>

            <% } else { %>

                <div class="table-container">

                    <table>
                        <caption>Lista de serviços cadastrados</caption>

                        <thead>
                            <tr>
                                <th scope="col">Serviço</th>
                                <th scope="col">Preço</th>
                                <th scope="col">Ações</th>
                            </tr>
                        </thead>

                        <tbody>

                            <% servicos.forEach(function(s) { %>

                                <tr>

                                    <td><%= s.nome %></td>

                                    <td>
                                        R$ <%= Number(s.preco).toFixed(2) %>
                                    </td>

                                    <td>

                                        <!-- Editar serviço -->

                                        <form
                                            action="/barbeiro/servicos/editar/<%= s.id %>"
                                            method="POST"
                                            aria-label="Editar serviço <%= s.nome %>"
                                        >

                                            <label for="nome-servico-<%= s.id %>">
                                                Nome do serviço
                                            </label>

                                            <input
                                                type="text"
                                                id="nome-servico-<%= s.id %>"
                                                name="nome"
                                                value="<%= s.nome %>"
                                                aria-label="Nome do serviço"
                                                required
                                                aria-required="true"
                                            >

                                            <label for="preco-servico-<%= s.id %>">
                                                Preço do serviço
                                            </label>

                                            <input
                                                type="number"
                                                id="preco-servico-<%= s.id %>"
                                                name="preco"
                                                value="<%= s.preco %>"
                                                step="0.01"
                                                min="0"
                                                aria-label="Preço do serviço"
                                                required
                                                aria-required="true"
                                            >

                                            <button
                                                type="submit"
                                                aria-label="Salvar edição de <%= s.nome %>"
                                            >
                                                Salvar
                                            </button>

                                        </form>

                                        <!-- Remover serviço -->

                                        <form
                                            action="/barbeiro/servicos/remover/<%= s.id %>"
                                            method="POST"
                                            aria-label="Remover serviço <%= s.nome %>"
                                        >

                                            <button
                                                type="submit"
                                                aria-label="Remover serviço <%= s.nome %>"
                                            >
                                                Remover
                                            </button>

                                        </form>

                                    </td>

                                </tr>

                            <% }); %>

                        </tbody>

                    </table>

                </div>

            <% } %>

        </section>

        <!-- Adicionar novo serviço -->

        <section aria-labelledby="titulo-adicionar-servico">

            <h2 id="titulo-adicionar-servico">
                Adicionar Serviço
            </h2>

            <div class="form-container">

                <form
                    action="/barbeiro/servicos/adicionar"
                    method="POST"
                    aria-label="Formulário para adicionar serviço"
                >

                    <label for="nome-servico">
                        Nome do serviço
                    </label>

                    <input
                        type="text"
                        id="nome-servico"
                        name="nome"
                        placeholder="Ex: Corte simples"
                        required
                        aria-required="true"
                    >

                    <label for="preco-servico">
                        Preço (R$)
                    </label>

                    <input
                        type="number"
                        id="preco-servico"
                        name="preco"
                        placeholder="Ex: 35.00"
                        step="0.01"
                        min="0"
                        required
                        aria-required="true"
                    >

                    <button
                        type="submit"
                        aria-label="Adicionar novo serviço"
                    >
                        Adicionar
                    </button>

                </form>

            </div>

        </section>

        <!-- Horários de funcionamento -->

        <section aria-labelledby="titulo-horarios">

            <h2 id="titulo-horarios">
                Horários de Funcionamento
            </h2>

            <% if (horarios.length === 0) { %>

                <p>Nenhum horário cadastrado ainda.</p>

            <% } else { %>

                <div class="table-container">

                    <table>
                        <caption>Horários de funcionamento por dia da semana</caption>

                        <thead>
                            <tr>
                                <th scope="col">Dia</th>
                                <th scope="col">Abertura</th>
                                <th scope="col">Fechamento</th>
                                <th scope="col">Intervalo</th>
                                <th scope="col">Ativo</th>
                                <th scope="col">Ações</th>
                            </tr>
                        </thead>

                        <tbody>

                            <% horarios.forEach(function(h) { %>

                                <tr>

                                    <td><%= h.dia_semana %></td>

                                    <td><%= h.hora_inicio %></td>

                                    <td><%= h.hora_fim %></td>

                                    <td>
                                        <%= h.intervalo_minutos %> min
                                    </td>

                                    <td>
                                        <%= h.ativo ? 'Sim' : 'Não' %>
                                    </td>

                                    <td>

                                        <!-- Editar horário -->

                                        <form
                                            action="/barbeiro/horarios/editar/<%= h.id %>"
                                            method="POST"
                                            aria-label="Editar horário de <%= h.dia_semana %>"
                                        >

                                            <label for="hora-inicio-<%= h.id %>">
                                                Abertura
                                            </label>

                                            <input
                                                type="time"
                                                id="hora-inicio-<%= h.id %>"
                                                name="hora_inicio"
                                                value="<%= h.hora_inicio %>"
                                                required
                                                aria-required="true"
                                            >

                                            <label for="hora-fim-<%= h.id %>">
                                                Fechamento
                                            </label>

                                            <input
                                                type="time"
                                                id="hora-fim-<%= h.id %>"
                                                name="hora_fim"
                                                value="<%= h.hora_fim %>"
                                                required
                                                aria-required="true"
                                            >

                                            <label for="intervalo-<%= h.id %>">
                                                Intervalo (min)
                                            </label>

                                            <input
                                                type="number"
                                                id="intervalo-<%= h.id %>"
                                                name="intervalo_minutos"
                                                value="<%= h.intervalo_minutos %>"
                                                min="10"
                                                max="120"
                                                required
                                                aria-required="true"
                                            >

                                            <label for="ativo-<%= h.id %>">

                                                <input
                                                    type="checkbox"
                                                    id="ativo-<%= h.id %>"
                                                    name="ativo"
                                                    <%= h.ativo ? 'checked' : '' %>
                                                    aria-label="Dia ativo"
                                                >

                                                <span>Aberto neste dia</span>

                                            </label>

                                            <button
                                                type="submit"
                                                aria-label="Salvar horário de <%= h.dia_semana %>"
                                            >
                                                Salvar
                                            </button>

                                        </form>

                                    </td>

                                </tr>

                            <% }); %>

                        </tbody>

                    </table>

                </div>

            <% } %>

        </section>

        <!-- Adicionar horário de funcionamento -->

        <section aria-labelledby="titulo-adicionar-horario">

            <h2 id="titulo-adicionar-horario">
                Adicionar Horário de Funcionamento
            </h2>

            <div class="form-container">

                <form
                    action="/barbeiro/horarios/adicionar"
                    method="POST"
                    aria-label="Formulário para adicionar horário de funcionamento"
                >

                    <label for="dia-semana">
                        Dia da semana
                    </label>

                    <select
                        id="dia-semana"
                        name="dia_semana"
                        required
                        aria-required="true"
                    >
                        <option value="">Selecione um dia</option>
                        <option value="segunda">Segunda-feira</option>
                        <option value="terca">Terça-feira</option>
                        <option value="quarta">Quarta-feira</option>
                        <option value="quinta">Quinta-feira</option>
                        <option value="sexta">Sexta-feira</option>
                        <option value="sabado">Sábado</option>
                        <option value="domingo">Domingo</option>
                    </select>

                    <label for="hora-inicio">
                        Abertura
                    </label>

                    <input
                        type="time"
                        id="hora-inicio"
                        name="hora_inicio"
                        required
                        aria-required="true"
                    >

                    <label for="hora-fim">
                        Fechamento
                    </label>

                    <input
                        type="time"
                        id="hora-fim"
                        name="hora_fim"
                        required
                        aria-required="true"
                    >

                    <label for="intervalo">
                        Intervalo entre clientes (min)
                    </label>

                    <input
                        type="number"
                        id="intervalo"
                        name="intervalo_minutos"
                        value="30"
                        min="10"
                        max="120"
                        required
                        aria-required="true"
                    >

                    <button
                        type="submit"
                        aria-label="Adicionar horário de funcionamento"
                    >
                        Adicionar
                    </button>

                </form>

            </div>

        </section>

    </main>

    <%- include('../partials/footer') %>

</body>
</html>
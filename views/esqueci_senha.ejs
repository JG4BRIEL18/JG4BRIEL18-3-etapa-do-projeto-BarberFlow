<!DOCTYPE html>
<html lang="pt-BR">

<%- include('partials/header') %>

<body>

    <%- include('partials/navbar_public') %>

    <main aria-label="Esqueci minha senha">

        <section aria-label="Formulário de recuperação de senha">
            <h2>Esqueci minha senha</h2>
            <p>Digite seu email cadastrado para receber o link de redefinição.</p>

            <div class="form-container">
                <form action="/esqueci-senha" method="POST">

                    <% if (typeof erro !== 'undefined' && erro) { %>
                        <p class="mensagem-erro"><%= erro %></p>
                    <% } %>

                    <% if (typeof sucesso !== 'undefined' && sucesso) { %>
                        <p class="mensagem-sucesso"><%= sucesso %></p>
                    <% } %>

                    <label for="email">Email</label>
                    <input
                        type="email"
                        id="email"
                        name="email"
                        required
                        aria-label="Digite seu email"
                    >

                    <button type="submit" aria-label="Enviar link de redefinição">
                        Enviar link
                    </button>

                </form>
            </div>

            <a class="botao" href="/login" aria-label="Voltar para o login">Voltar para o login</a>
        </section>

    </main>

    <%- include('partials/footer') %>

</body>
</html>
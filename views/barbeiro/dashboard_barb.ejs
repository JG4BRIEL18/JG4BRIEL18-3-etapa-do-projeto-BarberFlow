<!DOCTYPE html>
<html lang="pt-BR">

<%- include('../partials/header') %>

<body>

    <%- include('../partials/navbar_barbeiro') %>

    <main aria-label="Conteúdo principal do dashboard">

        <!-- Boas-vindas -->
        <section aria-labelledby="titulo-boas-vindas">
            <h2 id="titulo-boas-vindas">Painel do Barbeiro</h2>
            <p>Bem-vindo, <strong><%= nome %></strong>!</p>
            <p>Barbearia: <strong><%= barbearia %></strong></p>
        </section>

        <!-- Estatísticas -->
        <section aria-labelledby="titulo-estatisticas">
            <h2 id="titulo-estatisticas">Visão Geral do Mês</h2>

            <p>Total de agendamentos: <strong><%= totalMes %></strong></p>
            <p>Faturamento estimado: <strong>R$ <%= Number(faturamento).toFixed(2) %></strong></p>
        </section>

        <!-- Agendamentos de hoje -->
        <section aria-labelledby="titulo-agendamentos">
            <h2 id="titulo-agendamentos">Atendimentos de Hoje</h2>

            <% if (agendamentosHoje.length === 0) { %>
                <p>Nenhum atendimento agendado para hoje.</p>
            <% } else { %>

                <div class="table-container">
                    <table>
                        <caption>Lista de atendimentos de hoje</caption>

                        <thead>
                            <tr>
                                <th scope="col">Cliente</th>
                                <th scope="col">Serviço</th>
                                <th scope="col">Horário</th>
                                <th scope="col">Status</th>
                            </tr>
                        </thead>

                        <tbody>
                            <% agendamentosHoje.forEach(function(ag) { %>
                                <tr>
                                    <td><%= ag.cliente %></td>
                                    <td><%= ag.servico %></td>
                                    <td><%= ag.hora_agendamento %></td>
                                    <td><%= ag.status %></td>
                                </tr>
                            <% }); %>
                        </tbody>

                    </table>
                </div>

            <% } %>
        </section>

        <!-- Ações -->
        <section aria-labelledby="titulo-acoes">
            <h2 id="titulo-acoes">Ações</h2>

            <a href="/barbeiro/agenda" class="botao" 
            aria-label="Ir para gerenciar agenda">Gerenciar Agenda</a>
            <a href="/barbeiro/servicos" 
            class="botao" aria-label="Ir para gerenciar serviços">Gerenciar Serviços</a>
        </section>

    </main>

    <%- include('../partials/footer') %>

</body>
</html>